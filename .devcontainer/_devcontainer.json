{
  "name": "DevKit Java Enterprise & OpenCode",
  "dockerFile": "Dockerfile",
  "context": "..",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-tomcat",
        "iosw.opencode",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-1.8",
            "path": "/opt/java/jdk8",
            "default": true
          },
          {
            "name": "JavaSE-21",
            "path": "/opt/java/jdk21"
          }
        ],
        "java.home": "/opt/java/jdk8"
      }
    }
  },
  "forwardPorts": [8080, 8161],
  "portsAttributes": {
    "8080": {
      "label": "Tomcat App",
      "onAutoForward": "notify"
    },
    "8161": {
      "label": "ActiveMQ Console",
      "onAutoForward": "notify"
    }
  },
  "overrideCommand": true
}